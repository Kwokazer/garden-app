# Основные настройки приложения
APP_NAME="Garden API"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development # development, testing, production

# Настройки API
API_V1_STR="/api/v1"

# Настройки базы данных PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=garden
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Настройки Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Настройки безопасности JWT
# Сгенерировать секретный ключ: `openssl rand -hex 32`
JWT_SECRET_KEY=change_me_in_production_environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Настройки CORS
# Разделите URL запятыми без пробелов
CORS_ORIGINS=http://localhost:8080

# Настройки OAuth
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ВКонтакте OAuth
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=http://localhost:3000/auth/callback/vk

# Яндекс OAuth
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URI=http://localhost:3000/auth/callback/yandex

# Настройки электронной почты
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Garden <your_email@gmail.com>
EMAIL_TEMPLATES_DIR=app/infrastructure/external/templates/email

# Настройки для хранения файлов
STORAGE_TYPE=local # local, s3, cloud_storage
STORAGE_LOCAL_PATH=./uploads
# S3 настройки
S3_BUCKET_NAME=garden-app
S3_REGION=eu-central-1
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key 